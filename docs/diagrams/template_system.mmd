graph TB
    subgraph "Template Hierarchy"
        BASE[Base Template<br/>Common Requirements]
        INDUSTRY[Industry Templates<br/>e.g., financial, healthcare]
        USECASE[Use Case Templates<br/>e.g., invoice-processor, customer-360]
        CUSTOM[Custom Templates<br/>Organization-specific]
        
        BASE --> INDUSTRY
        INDUSTRY --> USECASE
        BASE --> CUSTOM
        INDUSTRY --> CUSTOM
    end
    
    subgraph "Template Components"
        T1[name: Template identifier]
        T2[description: Purpose]
        T3[dimensions: Quality requirements]
        T4[critical_fields: Must-have fields]
        T5[min_scores: Threshold values]
        T6[extends: Parent template]
    end
    
    subgraph "Template Usage"
        YAML[template.yaml<br/>Definition]
        ASSESS[Assessment<br/>Process]
        VALID[Validation<br/>Against Template]
        REPORT[Compliance<br/>Report]
        
        YAML --> ASSESS
        ASSESS --> VALID
        VALID --> REPORT
    end
    
    USECASE -.-> YAML
    
    style BASE fill:#1e293b,stroke:#0f172a,stroke-width:3px,color:#fff
