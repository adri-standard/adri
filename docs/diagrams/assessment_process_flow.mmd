    style D2 fill:#ff8cc3,stroke:#e64980
    style D3 fill:#ff8cc3,stroke:#e64980
    style D4 fill:#ff8cc3,stroke:#e64980
    style D5 fill:#ff8cc3,stroke:#e64980
